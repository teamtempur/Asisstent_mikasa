# ============================================
# KONFIGURASI BOT TELEGRAM CLAIM TUKTUK
# ============================================
# Copy file ini menjadi .env dan isi konfigurasi Anda
# JANGAN commit file .env ke repository!

# ============================================
# KONFIGURASI TELEGRAM (WAJIB)
# ============================================

# Token Bot Telegram dari @BotFather
# Cara mendapatkan:
# 1. Buka Telegram, cari @BotFather
# 2. Kirim /newbot
# 3. Ikuti instruksi
# 4. Copy token yang diberikan (format: 123456789:ABCdef...)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ID Admin yang diizinkan (pisahkan dengan koma)
# Kosongkan untuk mengizinkan semua orang
# Contoh: 123456789,987654321
ADMIN_IDS=

# ============================================
# KONFIGURASI GOOGLE SHEETS (WAJIB)
# ============================================

# Nama file credentials Google Sheets API (JSON)
# Download dari: Google Cloud Console > APIs & Services > Credentials
# Rename file menjadi credentials.json dan simpan di folder ini
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json

# Nama spreadsheet Google Sheets Anda
# Pastikan spreadsheet sudah di-share dengan service account
SPREADSHEET_NAME=Claim TukTuk

# Nama worksheet untuk data claim
WORKSHEET_CLAIM=Data Claim

# Nama worksheet untuk data user
WORKSHEET_USERS=Data Users

# ============================================
# PENGATURAN LAINNYA (OPSIONAL)
# ============================================

# Rate konversi KHR ke USD (default: 4000)
# 1 USD = 4000 KHR
EXCHANGE_RATE=4000

# Debug mode (True/False)
# Aktifkan untuk melihat log detail
DEBUG=False

# ============================================
# CATATAN KEAMANAN
# ============================================
# ⚠️ PENTING:
# - JANGAN share file .env ini ke orang lain
# - JANGAN commit file .env ke GitHub
# - JANGAN share credentials.json ke orang lain
# - File ini sudah ada di .gitignore
# ============================================
